{
  "manifest_version": 3,
  "name": "IsaGrade",
  "version": "1.0",
  "description": "Calculates minimal Grades needed for passing on Isa",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://appls.edufr.ch/isaweb/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "IsaGrade@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://appls.edufr.ch/isaweb/*"],
      "js": ["IsaGrade.js"]
    }
  ]
}
